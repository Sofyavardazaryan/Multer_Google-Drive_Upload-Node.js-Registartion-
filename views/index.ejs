<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Google Drive Upload System</title>

    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>

<div class="container">

    <h1>Google Drive Upload System</h1>

    <% if (!loggedIn) { %>
        <div class="auth-section">
            <a href="/auth/google">
                <button class="google-btn">
                    Login with Google
                </button>
            </a>

            <p class="error">
                Not logged in
            </p>
        </div>
    <% } else { %>
        <div class="auth-section">
            <p class="success">
                ✓ Logged in with Google
            </p>
        </div>
    <% } %>

    <div class="card">
        <h2>Register User</h2>

        <form action="/register" method="POST">

            <input
                type="text"
                name="name"
                placeholder="Enter name"
                required
            >

            <input
                type="email"
                name="email"
                placeholder="Enter email"
                required
            >

            <input
                type="password"
                name="password"
                placeholder="Enter password"
                required
            >

            <button type="submit">
                Register
            </button>

        </form>
    </div>

    <div class="card">
        <h2>Upload File To Google Drive</h2>

        <form
            action="/upload"
            method="POST"
            enctype="multipart/form-data"
        >

            <input
                type="file"
                name="avatar"
                required
            >

            <button type="submit">
                Upload File
            </button>

        </form>
    </div>

    <div class="card">
        <h2>Registered Users</h2>

        <% if(users.length === 0){ %>

            <p class="empty">
                No users found
            </p>

        <% } else { %>

            <div class="users">

                <% users.forEach(user => { %>

                    <div class="user-card">

                        <div>
                            <h3><%= user.name %></h3>
                            <p><%= user.email %></p>
                        </div>

                    </div>

                <% }) %>

            </div>

        <% } %>

    </div>

</div>

</body>
</html>